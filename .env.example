# =============================================
# BuhAI — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# --- Database (required) ---
# If your network has no IPv6, use the Supabase "Connection pooling" URI (pooler host) from Dashboard.
DATABASE_URL="postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"

# --- AI (required) ---
ANTHROPIC_API_KEY="your_anthropic_api_key"
OPENAI_API_KEY="your_openai_api_key"   # fallback

# --- Auth (required) ---
NEXTAUTH_SECRET="your-random-secret-32chars"
NEXTAUTH_URL="http://localhost:3000"

# --- Storage (optional — local fallback used if missing) ---
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="buh-ai-documents"
CLOUDFLARE_R2_ENDPOINT=""

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=""

# --- Payments (optional — mock used if missing) ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Supabase (optional frontend usage) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# --- Backend URL (used by frontend) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_URL="http://localhost:3001"

# --- OneID Uzbekistan (required for OneID login) ---
# Register at https://my.gov.uz/ru/pages/developer
ONE_ID_CLIENT_ID="your_oneid_client_id"
ONE_ID_CLIENT_SECRET="your_oneid_client_secret"
# OneID redirect URI must be: https://yourdomain.com/api/auth/oneid/callback
