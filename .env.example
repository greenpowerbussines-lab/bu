# =============================================
# BuhAI — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# --- Database (required) ---
# If your network has no IPv6, use the Supabase "Connection pooling" URI (pooler host) from Dashboard.
DATABASE_URL="postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"

# --- AI (required) ---
ANTHROPIC_API_KEY="your_anthropic_api_key"
OPENAI_API_KEY="your_openai_api_key"   # fallback

# --- Auth (required) ---
NEXTAUTH_SECRET="your-random-secret-32chars"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (optional, for Google login) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Storage (optional — local fallback used if missing) ---
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="buh-ai-documents"
CLOUDFLARE_R2_ENDPOINT=""

# --- Telegram (optional, for Telegram code login) ---
TELEGRAM_BOT_TOKEN=""

# --- SMTP Email (required for password reset emails) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BuhAI <no-reply@yourdomain.com>"

# --- Payments (optional — mock used if missing) ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Supabase (optional frontend usage) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# --- Backend URL (used by frontend) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_URL="http://localhost:3001"

# OneID and ERI login were removed from the web auth flow.
